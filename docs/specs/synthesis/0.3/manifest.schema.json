{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autophagy.sh/specs/synthesis/0.3/manifest.schema.json",
  "title": "Autophagy Local Model Manifest v0.3",
  "description": "Additive revision of synthesis-manifest/0.2 for agent-CLI-backed providers. Adds the `claude_cli` and `codex_cli` formats and an optional `model` field naming the identifier passed to the CLI's `--model` flag. Loading a manifest still never downloads a model or makes a network call. Agent-CLI providers reach the vendor's cloud through the user's own logged-in CLI and require explicit remote consent to run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "name",
    "format",
    "path",
    "revision",
    "capabilities",
    "resource_hints"
  ],
  "properties": {
    "spec_version": { "const": "synthesis-manifest/0.3" },
    "name": { "type": "string", "minLength": 1 },
    "format": {
      "enum": [
        "gguf",
        "ollama",
        "mlx",
        "openai_compatible",
        "claude_cli",
        "codex_cli",
        "deterministic"
      ]
    },
    "path": { "type": "string", "minLength": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "digest": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["mutation_synthesis", "embedding", "extraction"] }
    },
    "resource_hints": { "$ref": "#/$defs/resource_hints" },
    "timeouts": { "$ref": "#/$defs/timeouts" },
    "api_key_env": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "resource_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_memory_mb"],
      "properties": {
        "min_memory_mb": { "type": "integer", "minimum": 1 },
        "recommended_memory_mb": { "type": "integer", "minimum": 1 },
        "context_window_tokens": { "type": "integer", "minimum": 1 }
      }
    },
    "timeouts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "connect_ms": { "type": "integer", "minimum": 1 },
        "request_ms": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
