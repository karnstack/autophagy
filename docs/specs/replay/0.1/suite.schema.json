{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autophagy.sh/specs/replay/0.1/suite.schema.json",
  "title": "Autophagy Replay Suite v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "mutation_id", "scenarios"],
  "properties": {
    "spec_version": { "const": "replay-suite/0.1" },
    "mutation_id": { "type": "string", "pattern": "^mut_[A-Za-z0-9._:-]+$" },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    }
  },
  "$defs": {
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spec_version",
        "scenario_id",
        "source_event_ids",
        "observed_trigger_selectors",
        "expected_action"
      ],
      "properties": {
        "spec_version": { "const": "replay-scenario/0.1" },
        "scenario_id": { "type": "string", "pattern": "^rps_[A-Za-z0-9._:-]+$" },
        "source_event_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^evt_[A-Za-z0-9._:-]+$" }
        },
        "observed_trigger_selectors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "expected_action": { "enum": ["intervene", "no_op"] },
        "counterfactual_outcome": { "enum": ["expected_result", "contradiction"] },
        "note": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "expected_action": { "const": "intervene" } } },
          "then": { "required": ["counterfactual_outcome"] },
          "else": { "not": { "required": ["counterfactual_outcome"] } }
        }
      ]
    }
  }
}
